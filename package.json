{
  "name": "successmetrics-website",
  "private": true,
  "scripts": {
    "build": "node scripts/build-site.mjs",
    "prepreview": "npm run build",
    "pretest:static": "npm run build",
    "pretest:e2e": "npm run build",
    "pretest": "npm run build",
    "test": "npm run test:static && npm run test:e2e",
    "test:static": "vitest run",
    "test:netlify": "vitest run --config vitest.netlify.config.ts",
    "test:netlify:e2e": "playwright test tests/e2e/netlify-forms.spec.ts",
    "test:e2e": "playwright test",
    "preview": "python3 -m http.server 8080 --directory site"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "cheerio": "^1.0.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  }
}
