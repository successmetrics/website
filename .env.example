# Copy to .env for local `npm run dev` / verification scripts.
# On Netlify: Site configuration → Environment variables
#   - Scope must include "Functions" (or "All scopes"), not Builds only
#   - Redeploy after changing variables

# Notion careers integration
NOTION_TOKEN=
NOTION_JOBS_DATABASE_ID=
NOTION_APPLICATIONS_DATABASE_ID=

# Resend email notifications
RESEND_API_KEY=
CAREERS_NOTIFY_EMAIL=
CONTACT_NOTIFY_EMAIL=
RESEND_FROM_EMAIL=
RESEND_CONTACT_FROM_EMAIL=

# Google Analytics (optional — injected at build time)
GOOGLE_ANALYTICS_ID=
